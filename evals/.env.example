# Copy to <repo-root>/.env (already gitignored) and fill in.
#
# Both the LangWatch SDK + CLI and `node --env-file-if-exists=../.env`
# (used by the evals/ npm scripts) read these. Mint API keys at
# app.langwatch.ai → Settings → API Keys (or run `langwatch login --device`).

# LangWatch observability — project API key. The SDK uses this to attribute
# spans to your project; the CLI uses it for dataset/records/eval operations
# (no separate `langwatch login --device` needed when this is set).
LANGWATCH_API_KEY=

# Only required for service API keys (CI/CD). Personal keys already carry the
# project context.
LANGWATCH_PROJECT_ID=

# LangWatch endpoint (the AI gateway URL). The Anthropic-compatible endpoint
# is https://gateway.langwatch.ai/v1; the runner sets ANTHROPIC_BASE_URL from
# either LANGWATCH_ENDPOINT or ANTHROPIC_BASE_URL.
LANGWATCH_ENDPOINT=https://gateway.langwatch.ai/v1

# Virtual key for the AI gateway (`vk-lw-...`). The runner reads this as
# ANTHROPIC_AUTH_TOKEN when present.
LANGWATCH_VIRTUAL_AI_KEY=

# Optional escape hatch — direct Anthropic API key that bypasses the gateway
# entirely. Useful for one-off local smoke runs but you lose all LangWatch
# telemetry. Leave unset for normal operation.
LOCAL_ANTHROPIC_API_KEY=
