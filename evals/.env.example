# Copy to evals/.env (gitignored) and fill in.
#
# Mint values via `langwatch login --device` (issues a personal virtual key,
# writes config to ~/.langwatch/config.json). The harness reads from process.env
# but also picks up .env via node --env-file=evals/.env when wired in CI.

# LangWatch observability — your project's API key from app.langwatch.ai
# → Settings → API Keys. The TS SDK uses this to attribute spans to your
# project. setupObservability({serviceName: "skills-evals"}) reads it.
LANGWATCH_API_KEY=

# Only required for service API keys (CI/CD). Personal keys from
# `langwatch login --device` already have the project context.
LANGWATCH_PROJECT_ID=

# AI Gateway routing — point the Anthropic SDK (and `claude -p` when env-aware)
# at the gateway instead of api.anthropic.com. The gateway is Anthropic-API
# compatible at /v1/messages; no SDK changes needed.
ANTHROPIC_BASE_URL=https://gateway.langwatch.ai/v1
ANTHROPIC_AUTH_TOKEN=vk-lw-

# Optional fallback for local-only smoke runs that bypass the gateway. If
# unset, the runner refuses to invoke Claude (we don't want accidental
# direct-to-Anthropic calls that skip telemetry).
LOCAL_ANTHROPIC_API_KEY=
