{
  "name": "@0xdeafcafe/skills-evals",
  "version": "0.1.0",
  "private": true,
  "description": "Eval harness for the 0xdeafcafe-skills plugin. Two tiers: contract tests (no LLM) and pipeline fixtures (real SDK calls, optionally routed through langwatch's AI gateway).",
  "type": "module",
  "scripts": {
    "tier1": "tsx runners/run-tier1.ts",
    "tier2": "tsx runners/run-pipeline.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0"
  },
  "packageManager": "pnpm@10.15.1"
}
