# LangWatch SDK + dataset + experiment auth. Issued in the LangWatch dashboard
# under Settings → API keys. The `sk-lw-` / `project_` / `vk-lw-` prefixes
# match LangWatch's own format so the placeholders read as the right shape.
LANGWATCH_API_KEY="sk-lw-xxx"
LANGWATCH_PROJECT_ID="project_xxx"
LANGWATCH_VIRTUAL_AI_KEY="vk-lw-xxx"

# LangWatch dashboard / governance API origin (used by the SDK to attach
# traces, datasets, evaluations to your project). Different from the AI
# gateway URL below.
LANGWATCH_ENDPOINT="https://app.langwatch.ai"

# AI gateway base URL — where requests to the routed Anthropic / OpenAI /
# Gemini surface go. The eval runner sets ANTHROPIC_BASE_URL +
# ANTHROPIC_AUTH_TOKEN from this so `claude -p` (and the scenarios harness)
# route through LangWatch (telemetry, cost tracking, no Anthropic key in
# your env). LangWatch cloud default: https://gateway.langwatch.ai.
LANGWATCH_GATEWAY_URL="https://gateway.langwatch.ai"

# Bypass: when set, the runner sends ANTHROPIC_API_KEY directly to the
# Anthropic API instead of going through LangWatch. Useful for local
# debugging when the gateway is misconfigured.
# LOCAL_ANTHROPIC_API_KEY=""
