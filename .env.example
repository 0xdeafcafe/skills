# LangWatch SDK + dataset + experiment auth. Issued in the LangWatch dashboard
# under Settings → API keys.
LANGWATCH_API_KEY="<your-langwatch-api-key>"
LANGWATCH_PROJECT_ID="<your-langwatch-project-id>"

# AI gateway routing. The eval runner sets ANTHROPIC_BASE_URL +
# ANTHROPIC_AUTH_TOKEN from these so `claude -p` calls go through LangWatch
# (telemetry, cost tracking, no Anthropic key in your env).
LANGWATCH_ENDPOINT="<your-langwatch-gateway-base-url>"
LANGWATCH_VIRTUAL_AI_KEY="<your-langwatch-virtual-key>"

# Bypass: when set, the runner sends ANTHROPIC_API_KEY directly to the
# Anthropic API instead of going through LangWatch. Useful for local
# debugging when the gateway is misconfigured.
# LOCAL_ANTHROPIC_API_KEY=""
